{
  "expo": {
    "name": "SafeScan QR",
    "slug": "safescan-android",
    "scheme": "safescan",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/splash.png",
      "backgroundColor": "#0a0a0f"
    },
    "android": {
      "package": "com.safescan.qr",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon-foreground.png",
        "backgroundColor": "#0a0a0f"
      },
      "permissions": [
        "CAMERA",
        "INTERNET",
        "VIBRATE",
        "USE_BIOMETRIC"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "safescan"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "ios": {
      "bundleIdentifier": "com.safescan.qr",
      "infoPlist": {
        "NSCameraUsageDescription": "SafeScan needs camera access to scan QR codes.",
        "NSPhotoLibraryUsageDescription": "SafeScan needs photo access to upload QR images.",
        "NSPhotoLibraryAddUsageDescription": "SafeScan may save shared scan reports when you choose to export them.",
        "NSFaceIDUsageDescription": "SafeScan uses Face ID to protect saved credentials when enabled.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      [
        "expo-router",
        {
          "root": "./app"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "SafeScan needs camera to scan QR codes."
        }
      ],
      "expo-secure-store",
      "expo-notifications",
      "expo-font",
      "expo-web-browser"
    ],
    "extra": {
      "router": {
        "root": "./app"
      },
      "eas": {
        "projectId": "bd703b1e-4182-442c-8d98-40bb95007490"
      }
    },
    "owner": "fellowbeast"
  }
}
